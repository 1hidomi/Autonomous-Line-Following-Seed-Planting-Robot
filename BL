#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

// --- 传感器配置 ---
const int dataPins[] = {10, 11, 12}; // 0:Right, 1:Medium, 2:Left
const int numSensors = 3;
const int LINE_THRESHOLD = 500;      // 识别黑线的阈值

// --- 电机驱动配置 ---
MotoronI2C mc;
const uint8_t RIGHT_FRONT = 1; 
const uint8_t RIGHT_REAR  = 2; 
const uint8_t LEFT_REAR   = 3; 
const uint8_t LEFT_FRONT  = 4;

const int16_t MOVE_SPEED = 400;      // 前进速度

void setup() {
  Serial.begin(115200);
  
  // 初始化 Motoron (使用 Wire1)
  Wire1.begin();
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  // 设置加减速，让动作更平稳
  for (int i = 1; i <= 4; i++) {
    mc.setMaxAcceleration(i, 400);
    mc.setMaxDeceleration(i, 600);
  }

  stopAllMotors();
  Serial.println("Robot Ready: Moving forward when Black Line detected on Medium sensor.");
}

void loop() {
  // 1. 读取传感器数据
  unsigned long durations[3];
  readReflectance(durations);

  unsigned long mediumValue = durations[1]; // 中间传感器的值

  // 2. 串口打印调试信息
  Serial.print("Sensor Values -> Left: "); Serial.print(durations[2]);
  Serial.print(" | Medium: "); Serial.print(mediumValue);
  Serial.print(" | Right: "); Serial.print(durations[0]);

  // 3. 逻辑判断
  if (mediumValue > LINE_THRESHOLD) {
    Serial.println(" [ STATUS: BLACK LINE FOUND - MOVING FORWARD ]");
    moveForward(MOVE_SPEED);
  } else {
    Serial.println(" [ STATUS: NO LINE - STOPPED ]");
    stopAllMotors();
  }

  delay(50); // 稍微缩短延迟，提高反应速度
}

// --- 功能函数库 ---

// 读取反射率传感器（RC放电耗时逻辑）
void readReflectance(unsigned long* duration) {
  for (int i = 0; i < numSensors; i++) {
    pinMode(dataPins[i], OUTPUT);
    digitalWrite(dataPins[i], HIGH);
    delayMicroseconds(10); 
    pinMode(dataPins[i], INPUT);
    unsigned long startTime = micros();
    // 等待引脚变低或超时（3000微秒）
    while (digitalRead(dataPins[i]) == HIGH && (micros() - startTime) < 3000);
    duration[i] = micros() - startTime;
  }
}

// 所有电机停止
void stopAllMotors() {
  mc.setSpeed(RIGHT_FRONT, 0);
  mc.setSpeed(RIGHT_REAR, 0);
  mc.setSpeed(LEFT_REAR, 0);
  mc.setSpeed(LEFT_FRONT, 0);
}

// 直线前进
void moveForward(int16_t speed) {
  mc.setSpeed(RIGHT_FRONT, speed);
  mc.setSpeed(RIGHT_REAR,  speed);
  mc.setSpeed(LEFT_REAR,   speed);
  mc.setSpeed(LEFT_FRONT,  speed);
}
