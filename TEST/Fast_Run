#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

// FULL FORWARD MOTORON TEST
// Purpose:
// - Send the maximum useful Motoron command to all four motors.
// - Verify battery / motor power / Motoron output without encoder or IMU noise.
// - Lift the wheels before testing unless you are ready for the robot to move.

const uint8_t LOWER_MOTORON_ADDR = 0x11;
const uint8_t UPPER_MOTORON_ADDR = 0x10;

MotoronI2C mcLower(LOWER_MOTORON_ADDR);
MotoronI2C mcUpper(UPPER_MOTORON_ADDR);

// Lower shield: RF/RR/LR on M1/M2/M3.
// Upper shield: LF on M1.
const uint8_t RF = 1;
const uint8_t RR = 2;
const uint8_t LR = 3;
const uint8_t LF = 1;

// Keep the currently-loaded forward polarity.
const int8_t FWD_RF = -1;
const int8_t FWD_RR = 1;
const int8_t FWD_LR = -1;
const int8_t FWD_LF = -1;

// Motoron setSpeed is effectively limited to +/-800.
// A larger number will not extract more battery power through software.
const int16_t MOTORON_FULL_SPEED = 800;
const unsigned long START_DELAY_MS = 3000;
const unsigned long RUN_TIME_MS = 10000;
const unsigned long STATUS_INTERVAL_MS = 1000;

unsigned long runStartMs = 0;
unsigned long lastStatusMs = 0;
bool running = false;
bool finished = false;

int16_t clampMotoronSpeed(int16_t speed)
{
  return constrain(speed, -MOTORON_FULL_SPEED, MOTORON_FULL_SPEED);
}

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  mcLower.setSpeed(RF, clampMotoronSpeed(rf));
  mcLower.setSpeed(RR, clampMotoronSpeed(rr));
  mcLower.setSpeed(LR, clampMotoronSpeed(lr));
  mcUpper.setSpeed(LF, clampMotoronSpeed(lf));
}

void stopAllMotors()
{
  setMotorSpeeds(0, 0, 0, 0);
}

void driveForwardFullSpeed()
{
  setMotorSpeeds(
      MOTORON_FULL_SPEED * FWD_RF,
      MOTORON_FULL_SPEED * FWD_RR,
      MOTORON_FULL_SPEED * FWD_LR,
      MOTORON_FULL_SPEED * FWD_LF);
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0)
{
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  // Zero acceleration/deceleration limits tell Motoron to change speed immediately.
  // This is intentionally aggressive for a lifted-wheel maximum output test.
  mc.setMaxAcceleration(m1, 0);
  mc.setMaxDeceleration(m1, 0);
  mc.setSpeed(m1, 0);

  if (m2 != 0)
  {
    mc.setMaxAcceleration(m2, 0);
    mc.setMaxDeceleration(m2, 0);
    mc.setSpeed(m2, 0);
  }

  if (m3 != 0)
  {
    mc.setMaxAcceleration(m3, 0);
    mc.setMaxDeceleration(m3, 0);
    mc.setSpeed(m3, 0);
  }
}

void scanI2CBus(TwoWire &bus, const char *name)
{
  Serial.print("I2C | Scanning ");
  Serial.println(name);

  int count = 0;
  for (uint8_t address = 1; address < 127; address++)
  {
    bus.beginTransmission(address);
    uint8_t error = bus.endTransmission();

    if (error == 0)
    {
      Serial.print("I2C | Found 0x");
      if (address < 16)
      {
        Serial.print("0");
      }
      Serial.println(address, HEX);
      count++;
    }
  }

  if (count == 0)
  {
    Serial.println("I2C | No devices found.");
  }
}

void printRawForwardCommand()
{
  Serial.print("RAW | RF=");
  Serial.print(MOTORON_FULL_SPEED * FWD_RF);
  Serial.print(" RR=");
  Serial.print(MOTORON_FULL_SPEED * FWD_RR);
  Serial.print(" LR=");
  Serial.print(MOTORON_FULL_SPEED * FWD_LR);
  Serial.print(" LF=");
  Serial.println(MOTORON_FULL_SPEED * FWD_LF);
}

void startFullForwardRun()
{
  runStartMs = millis();
  lastStatusMs = 0;
  running = true;
  finished = false;

  Serial.println("RUN | FULL_FORWARD_MAX START");
  Serial.print("RUN | command speed = +/-");
  Serial.println(MOTORON_FULL_SPEED);
  printRawForwardCommand();
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  Serial.println("====================================");
  Serial.println("FULL FORWARD MAX MOTOR TEST");
  Serial.println("Motoron useful max command: +/-800");
  Serial.println("This code cannot raise battery voltage or bypass hardware current limits.");
  Serial.println("Lift wheels first. It will auto-stop after 10 seconds.");
  Serial.println("====================================");

  Wire1.begin();
  Wire1.setClock(400000);
  scanI2CBus(Wire1, "Wire1 Motoron bus");

  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);
  stopAllMotors();

  Serial.print("Starting full-speed forward in ");
  Serial.print(START_DELAY_MS / 1000);
  Serial.println(" seconds...");
  delay(START_DELAY_MS);

  startFullForwardRun();
}

void loop()
{
  if (finished)
  {
    stopAllMotors();
    delay(100);
    return;
  }

  if (!running)
  {
    stopAllMotors();
    delay(100);
    return;
  }

  unsigned long now = millis();
  driveForwardFullSpeed();

  if (now - lastStatusMs >= STATUS_INTERVAL_MS)
  {
    lastStatusMs = now;
    Serial.print("STATUS | FULL_FORWARD_MAX elapsed=");
    Serial.print(now - runStartMs);
    Serial.print("/");
    Serial.print(RUN_TIME_MS);
    Serial.println(" ms");
    printRawForwardCommand();
  }

  if (now - runStartMs >= RUN_TIME_MS)
  {
    stopAllMotors();
    running = false;
    finished = true;
    Serial.println("RUN | FULL_FORWARD_MAX DONE -> motors stopped.");
  }

  delay(5);
}
