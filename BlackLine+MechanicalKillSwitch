#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

// --- 宏定义参数 ---
#define KILL_SWITCH_PIN 13   
#define LINE_THRESHOLD  600  
#define BASE_SPEED      300  
#define TURN_SPEED      500  
#define SLOW_SPEED      50   
#define NUM_SENSORS     3

const int dataPins[NUM_SENSORS] = {10, 11, 12}; 
const uint8_t RF = 1, RR = 2, LR = 3, LF = 4;

MotoronI2C mc;

// --- 状态变量 ---
volatile bool isRunning = true;  // 初始设为正在运行
volatile unsigned long lastInterruptTime = 0; // 用于去抖

// --- 函数原型 ---
void init_hardware(void);
void read_reflectance(unsigned long *durations);
void drive_motors(int16_t left, int16_t right);
void handle_button_press(void);

void setup() {
    Serial.begin(115200);
    
    // 1. 初始化开关，设为中断
    pinMode(KILL_SWITCH_PIN, INPUT_PULLUP);
    attachInterrupt(digitalPinToInterrupt(KILL_SWITCH_PIN), handle_button_press, FALLING);

    // 2. Motoron 初始化
    Wire1.begin();
    mc.setBus(&Wire1);
    mc.reinitialize();
    mc.disableCrc();
    mc.clearResetFlag();

    for (uint8_t i = 1; i <= 4; i++) {
        mc.setMaxAcceleration(i, 400);
        mc.setMaxDeceleration(i, 800); // 停止时稍快一点
    }

    Serial.println("System Ready. Press Red Switch to Toggle Stop/Run.");
}

void loop() {
    // A. 如果状态是停止，则强制切断动力并跳过后续逻辑
    if (!isRunning) {
        drive_motors(0, 0);
        Serial.println(">>> PAUSED - Press Switch to Resume");
        delay(200); // 降低打印频率
        return; 
    }

    // B. 正常运行逻辑
    unsigned long s[NUM_SENSORS];
    read_reflectance(s);

    // 巡线决策逻辑
    if (s[2] > LINE_THRESHOLD) {        // 左
        drive_motors(SLOW_SPEED, TURN_SPEED);
    } 
    else if (s[0] > LINE_THRESHOLD) {   // 右
        drive_motors(TURN_SPEED, SLOW_SPEED);
    } 
    else if (s[1] > LINE_THRESHOLD) {   // 中
        drive_motors(BASE_SPEED, BASE_SPEED);
    } 
    else {                              // 丢线
        drive_motors(0, 0);
    }

    delay(20);
}

// ==========================================
// 中断服务：切换 跑/停 状态
// ==========================================
void handle_button_press() {
    unsigned long interruptTime = millis();
    // 简单的去抖逻辑：200毫秒内的连续触发被视为无效
    if (interruptTime - lastInterruptTime > 200) {
        isRunning = !isRunning; // 翻转布尔值
    }
    lastInterruptTime = interruptTime;
}

// ==========================================
// 其它功能函数 (与之前相同)
// ==========================================
void read_reflectance(unsigned long *durations) {
    for (int i = 0; i < NUM_SENSORS; i++) {
        pinMode(dataPins[i], OUTPUT);
        digitalWrite(dataPins[i], HIGH);
        delayMicroseconds(10);
        pinMode(dataPins[i], INPUT);
        unsigned long startTime = micros();
        while (digitalRead(dataPins[i]) == HIGH && (micros() - startTime) < 3000);
        durations[i] = micros() - startTime;
    }
}

void drive_motors(int16_t left, int16_t right) {
    mc.setSpeed(LR, -left);
    mc.setSpeed(LF, -left);
    mc.setSpeed(RF, -right);
    mc.setSpeed(RR, -right);
}
