#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>

const uint8_t LOWER_MOTORON_ADDR = 0x10;
const uint8_t UPPER_MOTORON_ADDR = 0x11;

MotoronI2C mcLower(LOWER_MOTORON_ADDR);
MotoronI2C mcUpper(UPPER_MOTORON_ADDR);

// Lower shield: RF/RR/LR on M1/M2/M3.
// Upper shield: LF on M1.
const uint8_t RF = 1;
const uint8_t RR = 2;
const uint8_t LR = 3;
const uint8_t LF = 1;

// QTR order: RIGHT, SLIGHT_RIGHT, MIDDLE, SLIGHT_LEFT, LEFT.
const uint8_t SENSOR_COUNT = 5;
const uint8_t SENSOR_PINS[SENSOR_COUNT] = {22, 24, 26, 28, 30};

// Saved final wiring map for later encoder work.
const uint8_t ENC_A[4] = {2, 4, 6, 8};
const uint8_t ENC_B[4] = {3, 5, 7, 9};

const uint8_t US_LEFT_TRIG = 31;
const uint8_t US_LEFT_ECHO = 32;
const uint8_t US_RIGHT_TRIG = 33;
const uint8_t US_RIGHT_ECHO = 34;
const uint8_t US_FRONT_TRIG = 37;
const uint8_t US_FRONT_ECHO = 39;

const unsigned int SENSOR_TIMEOUT_US = 3000;
const unsigned int LINE_THRESHOLD = 760;
const bool BLACK_LINE_IS_HIGH = true;

const bool SENSOR_DEBUG_MODE = false;
const bool ENABLE_LINE_CORRECTION = false;

const int16_t MAX_SPEED = 1000;
const int16_t FORWARD_SPEED = 550;
const int16_t PIVOT_SPEED = 1000;

const uint16_t FORWARD_PULSE_MS = 90;
const uint16_t SENSOR_SETTLE_MS = 35;
const uint16_t PRE_CORRECT_STOP_MS = 80;
const uint16_t AFTER_CORRECT_SETTLE_MS = 60;
const uint16_t MAX_CORRECT_MS = 1200;

unsigned int sensorValues[SENSOR_COUNT];
bool sensorOnLine[SENSOR_COUNT];

int lastDirection = 0; // -1 = left, 0 = center/unknown, 1 = right
int correctionDirection = 0;
unsigned long stateStartMs = 0;
unsigned long lastPrintMs = 0;

enum RobotState
{
  SENSE_LINE,
  FORWARD_PULSE,
  SENSOR_SETTLE,
  PRE_CORRECT_STOP,
  CORRECT_LEFT,
  CORRECT_RIGHT,
  AFTER_CORRECT_SETTLE
};

RobotState state = SENSE_LINE;

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  mcLower.setSpeed(RF, constrain(rf, -MAX_SPEED, MAX_SPEED));
  mcLower.setSpeed(RR, constrain(rr, -MAX_SPEED, MAX_SPEED));
  mcLower.setSpeed(LR, constrain(lr, -MAX_SPEED, MAX_SPEED));
  mcUpper.setSpeed(LF, constrain(lf, -MAX_SPEED, MAX_SPEED));
}

void stopAllMotors()
{
  setMotorSpeeds(0, 0, 0, 0);
}

void driveForward(int16_t speed)
{
  // LF is on the upper Motoron's M1 and is physically reversed.
  setMotorSpeeds(speed, speed, speed, -speed);
}

void pivotRight(int16_t speed)
{
  // Right side backward, left side forward.
  setMotorSpeeds(-speed, -speed, speed, speed);
}

void pivotLeft(int16_t speed)
{
  // Left side backward, right side forward.
  setMotorSpeeds(speed, speed, -speed, -speed);
}

void scanI2CBus(TwoWire &bus, const char *name)
{
  Serial.print("Scanning ");
  Serial.print(name);
  Serial.println("...");

  for (uint8_t address = 1; address < 127; address++)
  {
    bus.beginTransmission(address);
    uint8_t error = bus.endTransmission();

    if (error == 0)
    {
      Serial.print("  Found I2C device at 0x");
      if (address < 16)
      {
        Serial.print("0");
      }
      Serial.println(address, HEX);
    }
  }
}

unsigned int readReflectancePin(uint8_t pin)
{
  pinMode(pin, OUTPUT);
  digitalWrite(pin, HIGH);
  delayMicroseconds(10);

  pinMode(pin, INPUT);

  unsigned long start = micros();
  while (digitalRead(pin) == HIGH)
  {
    if (micros() - start >= SENSOR_TIMEOUT_US)
    {
      return SENSOR_TIMEOUT_US;
    }
  }

  return (unsigned int)(micros() - start);
}

void readSensors()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    sensorValues[i] = readReflectancePin(SENSOR_PINS[i]);
    bool highMeansLine = sensorValues[i] >= LINE_THRESHOLD;
    sensorOnLine[i] = BLACK_LINE_IS_HIGH ? highMeansLine : !highMeansLine;
  }
}

bool anySensorOnLine()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    if (sensorOnLine[i])
    {
      return true;
    }
  }

  return false;
}

void printSensors(const char *label)
{
  if (millis() - lastPrintMs < 100)
  {
    return;
  }

  Serial.print(label);
  Serial.print(" [R,SR,M,SL,L]: ");

  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    Serial.print(sensorValues[i]);
    Serial.print(sensorOnLine[i] ? "*" : " ");
    Serial.print(" ");
  }

  Serial.print("| lastDir=");
  Serial.print(lastDirection);
  Serial.print(" corrDir=");
  Serial.println(correctionDirection);

  lastPrintMs = millis();
}

void enterState(RobotState nextState)
{
  state = nextState;
  stateStartMs = millis();

  switch (state)
  {
    case SENSE_LINE:
      break;

    case FORWARD_PULSE:
      Serial.println("State: FORWARD_PULSE");
      break;

    case SENSOR_SETTLE:
      stopAllMotors();
      break;

    case PRE_CORRECT_STOP:
      Serial.println("State: PRE_CORRECT_STOP");
      stopAllMotors();
      break;

    case CORRECT_LEFT:
      Serial.println("State: CORRECT_LEFT");
      break;

    case CORRECT_RIGHT:
      Serial.println("State: CORRECT_RIGHT");
      break;

    case AFTER_CORRECT_SETTLE:
      stopAllMotors();
      break;
  }
}

void senseLineStep()
{
  readSensors();
  printSensors(SENSOR_DEBUG_MODE ? "QTR_DEBUG" : "SENSE");

  if (SENSOR_DEBUG_MODE)
  {
    stopAllMotors();
    return;
  }

  // Sensor order: [0] right, [1] slight right, [2] middle,
  // [3] slight left, [4] left.
  if (sensorOnLine[2])
  {
    lastDirection = 0;
    correctionDirection = 0;
    enterState(FORWARD_PULSE);
    return;
  }

  if (sensorOnLine[3] || sensorOnLine[4])
  {
    lastDirection = -1;

    if (ENABLE_LINE_CORRECTION)
    {
      correctionDirection = -1;
      enterState(PRE_CORRECT_STOP);
    }
    else
    {
      stopAllMotors();
    }
    return;
  }

  if (sensorOnLine[1] || sensorOnLine[0])
  {
    lastDirection = 1;

    if (ENABLE_LINE_CORRECTION)
    {
      correctionDirection = 1;
      enterState(PRE_CORRECT_STOP);
    }
    else
    {
      stopAllMotors();
    }
    return;
  }

  if (!anySensorOnLine() && ENABLE_LINE_CORRECTION && lastDirection != 0)
  {
    correctionDirection = lastDirection;
    enterState(PRE_CORRECT_STOP);
    return;
  }

  stopAllMotors();
}

void correctionStep()
{
  readSensors();
  printSensors(correctionDirection < 0 ? "CORRECT_LEFT" : "CORRECT_RIGHT");

  if (sensorOnLine[2])
  {
    stopAllMotors();
    enterState(AFTER_CORRECT_SETTLE);
    return;
  }

  if (millis() - stateStartMs >= MAX_CORRECT_MS)
  {
    stopAllMotors();
    enterState(AFTER_CORRECT_SETTLE);
    return;
  }

  if (correctionDirection < 0)
  {
    pivotLeft(PIVOT_SPEED);
  }
  else if (correctionDirection > 0)
  {
    pivotRight(PIVOT_SPEED);
  }
  else
  {
    stopAllMotors();
  }
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0)
{
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(m1, 800);
  mc.setMaxDeceleration(m1, 900);

  if (m2 != 0)
  {
    mc.setMaxAcceleration(m2, 800);
    mc.setMaxDeceleration(m2, 900);
  }

  if (m3 != 0)
  {
    mc.setMaxAcceleration(m3, 800);
    mc.setMaxDeceleration(m3, 900);
  }
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  Wire1.begin();
  scanI2CBus(Wire1, "Wire1 for Motorons");

  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);

  stopAllMotors();

  Serial.println("Line follower ready. Lower=0x10, Upper=0x11, IMU/Kill disabled.");
  Serial.println("Correction disabled for this pass: middle line -> forward pulse, side line -> stop.");
  delay(1500);

  enterState(SENSE_LINE);
}

void loop()
{
  switch (state)
  {
    case SENSE_LINE:
      senseLineStep();
      break;

    case FORWARD_PULSE:
      driveForward(FORWARD_SPEED);
      if (millis() - stateStartMs >= FORWARD_PULSE_MS)
      {
        stopAllMotors();
        enterState(SENSOR_SETTLE);
      }
      break;

    case SENSOR_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= SENSOR_SETTLE_MS)
      {
        enterState(SENSE_LINE);
      }
      break;

    case PRE_CORRECT_STOP:
      stopAllMotors();
      if (millis() - stateStartMs >= PRE_CORRECT_STOP_MS)
      {
        if (correctionDirection < 0)
        {
          enterState(CORRECT_LEFT);
        }
        else if (correctionDirection > 0)
        {
          enterState(CORRECT_RIGHT);
        }
        else
        {
          enterState(SENSE_LINE);
        }
      }
      break;

    case CORRECT_LEFT:
    case CORRECT_RIGHT:
      correctionStep();
      break;

    case AFTER_CORRECT_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= AFTER_CORRECT_SETTLE_MS)
      {
        enterState(SENSE_LINE);
      }
      break;
  }

  delay(5);
}
