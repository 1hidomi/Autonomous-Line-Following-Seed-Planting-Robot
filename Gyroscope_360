#include <Arduino.h>
#include <Wire.h>
#include <Motoron.h>
#include "ICM_20948.h"

MotoronI2C mc;
ICM_20948_I2C imu;

// =====================
// 当前车轮布局
// =====================
const uint8_t RF = 1;  // M1 右前
const uint8_t RR = 2;  // M2 右后
const uint8_t LR = 3;  // M3 左后
const uint8_t LF = 4;  // M4 左前

// =====================
// 你已经确认正确的电机方向修正
// =====================
const int8_t DIR_RF = 1;
const int8_t DIR_RR = 1;
const int8_t DIR_LR = -1;
const int8_t DIR_LF = -1;

// =====================
// 转向速度设置
// =====================
// 主转向速度
const int16_t FAST_RF = 1000;
const int16_t FAST_RR = 1000;
const int16_t FAST_LR = 1000;
const int16_t FAST_LF = 1000;

// 接近 90 度时降速，减少冲过头
const int16_t SLOW_RF = 600;
const int16_t SLOW_RR = 600;
const int16_t SLOW_LR = 600;
const int16_t SLOW_LF = 600;

// 目标角度
const float TARGET_ANGLE_DEG = 360;

// 到这个角度以后开始慢速
const float SLOW_DOWN_ANGLE_DEG = 300;

// 如果你发现总是冲过头，比如停在 100°，可以把这个改成 85 或 80
const float STOP_ANGLE_DEG = 340;

// ICM20948 地址:
// AD0 = 0 -> 0x68
// AD0 = 1 -> 0x69
bool imuAd0Val = true;

float gyroZBias = 0.0;
float yawDeg = 0.0;

unsigned long lastUpdateMicros = 0;
unsigned long lastPrintTime = 0;

bool finished = false;

void scanI2CBus(TwoWire &bus, const char *name)
{
  Serial.print("Scanning ");
  Serial.print(name);
  Serial.println("...");

  int deviceCount = 0;

  for (uint8_t address = 1; address < 127; address++)
  {
    bus.beginTransmission(address);
    uint8_t error = bus.endTransmission();

    if (error == 0)
    {
      Serial.print("  Found I2C device at 0x");
      if (address < 16)
      {
        Serial.print("0");
      }
      Serial.println(address, HEX);
      deviceCount++;
    }
  }

  if (deviceCount == 0)
  {
    Serial.println("  No I2C devices found.");
  }
}

bool initIMU()
{
  const bool ad0Values[] = {false, true};

  for (uint8_t i = 0; i < 2; i++)
  {
    imuAd0Val = ad0Values[i];

    Serial.print("Trying ICM20948 AD0=");
    Serial.print(imuAd0Val ? 1 : 0);
    Serial.print(" address 0x");
    Serial.println(imuAd0Val ? "69" : "68");

    imu.begin(Wire, imuAd0Val);

    Serial.print("IMU status: ");
    Serial.println(imu.statusString());

    if (imu.status == ICM_20948_Stat_Ok)
    {
      Serial.print("ICM20948 ready at 0x");
      Serial.println(imuAd0Val ? "69" : "68");
      return true;
    }

    delay(100);
  }

  return false;
}

// =====================
// Motor control
// =====================
void stopAllMotors()
{
  mc.setSpeed(RF, 0);
  mc.setSpeed(RR, 0);
  mc.setSpeed(LR, 0);
  mc.setSpeed(LF, 0);
}

void spinClockwise(int16_t speedRF, int16_t speedRR, int16_t speedLR, int16_t speedLF)
{
  // 保留你原本确认正确的顺时针旋转逻辑
  // 右侧轮子向后，左侧轮子向前

  mc.setSpeed(RF, -speedRF * DIR_RF);
  mc.setSpeed(RR, -speedRR * DIR_RR);

  mc.setSpeed(LR,  speedLR * DIR_LR);
  mc.setSpeed(LF,  speedLF * DIR_LF);
}

// =====================
// IMU calibration
// =====================
void calibrateGyroZ()
{
  Serial.println("Calibrating gyro Z. Keep car still...");

  const int samples = 300;
  float sum = 0.0;
  int count = 0;

  while (count < samples)
  {
    if (imu.dataReady())
    {
      imu.getAGMT();
      sum += imu.gyrZ();
      count++;
    }

    delay(5);
  }

  gyroZBias = sum / samples;

  Serial.print("Gyro Z bias = ");
  Serial.println(gyroZBias, 6);
}

// =====================
// Setup
// =====================
void setup()
{
  Serial.begin(115200);
  delay(1000);

  // =====================
  // ICM20948 on Wire: D20 SDA, D21 SCL
  // =====================
  Wire.begin();
  Wire.setClock(400000);
  scanI2CBus(Wire, "Wire for IMU");

  bool imuReady = false;

  while (!imuReady)
  {
    imuReady = initIMU();

    if (!imuReady)
    {
      Serial.println("IMU not ready. Check SDA/SCL, 3.3V/GND, and AD0 address. Retrying...");
      delay(500);
    }
  }

  // =====================
  // Motoron on Wire1
  // =====================
  Wire1.begin();
  mc.setBus(&Wire1);

  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(RF, 800);
  mc.setMaxDeceleration(RF, 900);

  mc.setMaxAcceleration(RR, 800);
  mc.setMaxDeceleration(RR, 900);

  mc.setMaxAcceleration(LR, 800);
  mc.setMaxDeceleration(LR, 900);

  mc.setMaxAcceleration(LF, 800);
  mc.setMaxDeceleration(LF, 900);

  stopAllMotors();

  Serial.println("Clockwise 90 degree turn test with ICM20948");
  Serial.println("Motor directions copied from your working code.");
  Serial.println("Keep car still for gyro calibration.");

  delay(1000);
  calibrateGyroZ();

  Serial.println("Start turning in 2 seconds...");
  delay(2000);

  yawDeg = 0.0;
  lastUpdateMicros = micros();
}

// =====================
// Loop
// =====================
void loop()
{
  if (finished)
  {
    stopAllMotors();

    if (imu.dataReady() && millis() - lastPrintTime >= 1000)
    {
      imu.getAGMT();

      Serial.print("Stopped | Yaw: ");
      Serial.print(yawDeg, 2);
      Serial.print(" deg | GyroZ raw: ");
      Serial.print(imu.gyrZ(), 2);
      Serial.println(" dps");

      lastPrintTime = millis();
    }

    delay(100);
    return;
  }

  if (imu.dataReady())
  {
    imu.getAGMT();

    unsigned long nowMicros = micros();
    float dt = (nowMicros - lastUpdateMicros) / 1000000.0;
    lastUpdateMicros = nowMicros;

    float gyroZ = imu.gyrZ() - gyroZBias;

    // 积分得到 yaw 角度
    yawDeg += gyroZ * dt;

    float absYaw = abs(yawDeg);

    if (absYaw < STOP_ANGLE_DEG)
    {
      if (absYaw < SLOW_DOWN_ANGLE_DEG)
      {
        spinClockwise(FAST_RF, FAST_RR, FAST_LR, FAST_LF);
      }
      else
      {
        spinClockwise(SLOW_RF, SLOW_RR, SLOW_LR, SLOW_LF);
      }
    }
    else
    {
      stopAllMotors();
      finished = true;

      Serial.println("==============================");
      Serial.println("Reached target angle. Stop.");
      Serial.print("Final yaw reading: ");
      Serial.print(yawDeg, 2);
      Serial.println(" deg");
      Serial.print("Absolute yaw: ");
      Serial.print(absYaw, 2);
      Serial.println(" deg");
      Serial.println("==============================");
      return;
    }

    if (millis() - lastPrintTime >= 100)
    {
      Serial.print("Yaw: ");
      Serial.print(yawDeg, 2);
      Serial.print(" deg");

      Serial.print(" | Abs: ");
      Serial.print(absYaw, 2);

      Serial.print(" | GyroZ: ");
      Serial.print(gyroZ, 2);

      if (absYaw < SLOW_DOWN_ANGLE_DEG)
      {
        Serial.println(" | FAST");
      }
      else
      {
        Serial.println(" | SLOW");
      }

      lastPrintTime = millis();
    }
  }

  delay(5);
}
