// VERSION: LINE_FOLLOWER_FIXED_LEFT_THEN_CROSS_RIGHT_REVERSED_FIND_V2
// Loaded from saved_versions/line_follower_working_2026-05-19.cpp.
// Current test changes: fixed route, first left 90, then right 90 at intersection.
// Find-line swing order after turns is reversed from the previous test.

#include <Arduino.h>
#include <math.h>
#include <Wire.h>
#include <Motoron.h>
#include "ICM_20948.h"

const uint8_t LOWER_MOTORON_ADDR = 0x10;
const uint8_t UPPER_MOTORON_ADDR = 0x11;

MotoronI2C mcLower(LOWER_MOTORON_ADDR);
MotoronI2C mcUpper(UPPER_MOTORON_ADDR);

// ICM-20948 on SDA/SCL, D20/D21.
ICM_20948_I2C imu;
bool imuAd0Val = true;
float gyroZBias = 0.0;
float yawDeg = 0.0;
float turnStartYawDeg = 0.0;
unsigned long lastUpdateMicros = 0;

// Lower shield: RF/RR/LR on M1/M2/M3.
// Upper shield: LF on M1.
const uint8_t RF = 1;
const uint8_t RR = 2;
const uint8_t LR = 3;
const uint8_t LF = 1;

// Raw Motoron polarity for physical forward motion.
const int8_t FWD_RF = 1;
const int8_t FWD_RR = 1;
const int8_t FWD_LR = -1;
const int8_t FWD_LF = -1;

// QTR order: RIGHT, SLIGHT_RIGHT, MIDDLE, SLIGHT_LEFT, LEFT.
const uint8_t SENSOR_COUNT = 5;
const uint8_t SENSOR_PINS[SENSOR_COUNT] = {22, 24, 26, 28, 30};

// Saved final wiring map for later encoder work.
const uint8_t ENC_A[4] = {2, 4, 6, 8};
const uint8_t ENC_B[4] = {3, 5, 7, 9};

const uint8_t US_LEFT_TRIG = 31;
const uint8_t US_LEFT_ECHO = 32;
const uint8_t US_RIGHT_TRIG = 33;
const uint8_t US_RIGHT_ECHO = 34;
const uint8_t US_FRONT_TRIG = 37;
const uint8_t US_FRONT_ECHO = 39;

const unsigned int SENSOR_TIMEOUT_US = 3000;
const unsigned int LINE_THRESHOLD = 760;
const unsigned int SIDE_CORRECTION_THRESHOLD = LINE_THRESHOLD;
const unsigned int STRONG_SIDE_CORRECTION_THRESHOLD = 1100;
const bool BLACK_LINE_IS_HIGH = true;

const bool SENSOR_DEBUG_MODE = false;
const bool ENABLE_LINE_CORRECTION = true;

const int16_t MAX_SPEED = 1000;
const int16_t FORWARD_SPEED = 700;
const int16_t MIN_CORRECTION_SPEED = 600;
const int16_t PIVOT_SPEED = 850;
const int16_t RIGHT_ANGLE_FAST_SPEED = 650;
const int16_t RIGHT_ANGLE_SLOW_SPEED = 600;

const uint16_t FORWARD_PULSE_MS = 90;
const uint16_t SENSOR_SETTLE_MS = 35;
const uint16_t PRE_CORRECT_STOP_MS = 80;
const uint16_t CORRECTION_PULSE_MS = 75;
const uint16_t STRONG_CORRECTION_PULSE_MS = 110;
const uint16_t AFTER_CORRECT_SETTLE_MS = 60;
const float PRE_TURN_FORWARD_CM = 11.0;
const float PRE_TURN_MS_PER_CM_AT_SPEED_700 = 55.6;
const uint16_t PRE_TURN_FORWARD_MS = (uint16_t)(PRE_TURN_FORWARD_CM * PRE_TURN_MS_PER_CM_AT_SPEED_700 + 0.5);
const uint16_t AFTER_TURN_SETTLE_MS = 120;
const uint16_t RIGHT_ANGLE_TIMEOUT_MS = 3500;
const float RIGHT_ANGLE_TARGET_DEG = 88.0;
const float RIGHT_ANGLE_SLOW_DOWN_DEG = 70.0;
const int16_t FIND_LINE_SPEED = 800;
const uint16_t FIND_LINE_SMALL_MS = 150;
const uint16_t FIND_LINE_BIG_MS = 650;

unsigned int sensorValues[SENSOR_COUNT];
bool sensorOnLine[SENSOR_COUNT];

int lastDirection = 0; // -1 = left, 0 = center/unknown, 1 = right
int correctionDirection = 0;
uint16_t activeCorrectionPulseMs = CORRECTION_PULSE_MS;
unsigned long stateStartMs = 0;
unsigned long lastPrintMs = 0;
unsigned long ignoreRightAngleUntilMs = 0;
int lastTurnDirection = 0; // -1 = left, 1 = right
uint8_t completedRouteTurns = 0;
int pendingTurnDirection = 0; // -1 = left, 1 = right
int findLineFirstDirection = 0; // -1 = left first, 1 = right first

enum RobotState
{
  SENSE_LINE,
  FORWARD_PULSE,
  SENSOR_SETTLE,
  PRE_CORRECT_STOP,
  CORRECT_LEFT,
  CORRECT_RIGHT,
  AFTER_CORRECT_SETTLE,
  PRE_TURN_FORWARD_LEFT,
  PRE_TURN_FORWARD_RIGHT,
  TURN_LEFT_90,
  TURN_RIGHT_90,
  AFTER_TURN_SETTLE,
  FIND_LINE_SMALL_LEFT,
  FIND_LINE_SMALL_RIGHT,
  FIND_LINE_BIG_LEFT,
  FIND_LINE_BIG_RIGHT,
  LINE_LOST_STOP
};

RobotState state = SENSE_LINE;

void enterState(RobotState nextState);
void printSensors(const char *label);

void setMotorSpeeds(int16_t rf, int16_t rr, int16_t lr, int16_t lf)
{
  mcLower.setSpeed(RF, constrain(rf, -MAX_SPEED, MAX_SPEED));
  mcLower.setSpeed(RR, constrain(rr, -MAX_SPEED, MAX_SPEED));
  mcLower.setSpeed(LR, constrain(lr, -MAX_SPEED, MAX_SPEED));
  mcUpper.setSpeed(LF, constrain(lf, -MAX_SPEED, MAX_SPEED));
}

void stopAllMotors()
{
  setMotorSpeeds(0, 0, 0, 0);
}

void driveBySide(int16_t leftSpeed, int16_t rightSpeed)
{
  setMotorSpeeds(
      rightSpeed * FWD_RF,
      rightSpeed * FWD_RR,
      leftSpeed * FWD_LR,
      leftSpeed * FWD_LF);
}

void driveForward(int16_t speed)
{
  driveBySide(speed, speed);
}

void pivotRight(int16_t speed)
{
  // Right side backward, left side forward.
  driveBySide(speed, -speed);
}

void pivotLeft(int16_t speed)
{
  // Left side backward, right side forward.
  driveBySide(-speed, speed);
}

void scanI2CBus(TwoWire &bus, const char *name)
{
  Serial.print("Scanning ");
  Serial.print(name);
  Serial.println("...");

  for (uint8_t address = 1; address < 127; address++)
  {
    bus.beginTransmission(address);
    uint8_t error = bus.endTransmission();

    if (error == 0)
    {
      Serial.print("  Found I2C device at 0x");
      if (address < 16)
      {
        Serial.print("0");
      }
      Serial.println(address, HEX);
    }
  }
}

bool initIMU()
{
  const bool ad0Values[] = {false, true};

  for (uint8_t i = 0; i < 2; i++)
  {
    imuAd0Val = ad0Values[i];

    Serial.print("IMU | Trying AD0=");
    Serial.print(imuAd0Val ? 1 : 0);
    Serial.print(" address 0x");
    Serial.println(imuAd0Val ? "69" : "68");

    imu.begin(Wire, imuAd0Val);
    Serial.print("IMU | Status: ");
    Serial.println(imu.statusString());

    if (imu.status == ICM_20948_Stat_Ok)
    {
      Serial.print("IMU | Ready at 0x");
      Serial.println(imuAd0Val ? "69" : "68");
      return true;
    }

    delay(100);
  }

  return false;
}

void calibrateGyroZ()
{
  Serial.println("IMU | Calibrating gyro Z. Keep the car still...");

  const int samples = 300;
  const unsigned long timeoutMs = 6000;
  float sum = 0.0;
  int count = 0;
  unsigned long startMs = millis();

  while (count < samples && millis() - startMs < timeoutMs)
  {
    if (imu.dataReady())
    {
      imu.getAGMT();
      sum += imu.gyrZ();
      count++;
    }
    delay(5);
  }

  gyroZBias = count > 0 ? sum / count : 0.0;

  Serial.print("IMU | Gyro Z bias = ");
  Serial.print(gyroZBias, 6);
  Serial.print(" from ");
  Serial.print(count);
  Serial.println(" samples");
}

void updateYaw()
{
  if (!imu.dataReady())
  {
    return;
  }

  imu.getAGMT();

  unsigned long nowMicros = micros();
  if (lastUpdateMicros == 0)
  {
    lastUpdateMicros = nowMicros;
    return;
  }

  float dt = (nowMicros - lastUpdateMicros) / 1000000.0;
  lastUpdateMicros = nowMicros;

  if (dt <= 0.0 || dt > 0.25)
  {
    return;
  }

  yawDeg += (imu.gyrZ() - gyroZBias) * dt;
}

float rightAngleTurnDeg()
{
  return fabs(yawDeg - turnStartYawDeg);
}

unsigned int readReflectancePin(uint8_t pin)
{
  pinMode(pin, OUTPUT);
  digitalWrite(pin, HIGH);
  delayMicroseconds(10);

  pinMode(pin, INPUT);

  unsigned long start = micros();
  while (digitalRead(pin) == HIGH)
  {
    if (micros() - start >= SENSOR_TIMEOUT_US)
    {
      return SENSOR_TIMEOUT_US;
    }
  }

  return (unsigned int)(micros() - start);
}

void readSensors()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    sensorValues[i] = readReflectancePin(SENSOR_PINS[i]);
    bool highMeansLine = sensorValues[i] >= LINE_THRESHOLD;
    sensorOnLine[i] = BLACK_LINE_IS_HIGH ? highMeansLine : !highMeansLine;
  }
}

bool anySensorOnLine()
{
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    if (sensorOnLine[i])
    {
      return true;
    }
  }

  return false;
}

bool centerOrAnySensorOnLine()
{
  readSensors();
  printSensors("FIND_LINE");
  return anySensorOnLine();
}

bool sensorAboveCorrectionThreshold(uint8_t index)
{
  return sensorValues[index] >= SIDE_CORRECTION_THRESHOLD;
}

bool leftCorrectionRequested()
{
  return sensorAboveCorrectionThreshold(3) || sensorAboveCorrectionThreshold(4);
}

bool rightCorrectionRequested()
{
  return sensorAboveCorrectionThreshold(0) || sensorAboveCorrectionThreshold(1);
}

bool sensorAboveStrongCorrectionThreshold(uint8_t index)
{
  return sensorValues[index] >= STRONG_SIDE_CORRECTION_THRESHOLD;
}

bool leftStrongCorrectionRequested()
{
  return sensorAboveStrongCorrectionThreshold(3) || sensorAboveStrongCorrectionThreshold(4);
}

bool rightStrongCorrectionRequested()
{
  return sensorAboveStrongCorrectionThreshold(0) || sensorAboveStrongCorrectionThreshold(1);
}

bool leftRightAngleRequested()
{
  return sensorValues[4] >= STRONG_SIDE_CORRECTION_THRESHOLD &&
         (sensorOnLine[3] || !sensorOnLine[2]);
}

bool rightRightAngleRequested()
{
  return sensorValues[0] >= STRONG_SIDE_CORRECTION_THRESHOLD &&
         (sensorOnLine[1] || !sensorOnLine[2]);
}

uint8_t sensorsOnLineCount()
{
  uint8_t count = 0;
  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    if (sensorOnLine[i])
    {
      count++;
    }
  }
  return count;
}

bool intersectionRequested()
{
  bool bothOuterStrong = sensorValues[0] >= STRONG_SIDE_CORRECTION_THRESHOLD &&
                         sensorValues[4] >= STRONG_SIDE_CORRECTION_THRESHOLD;
  return bothOuterStrong || sensorsOnLineCount() >= 4;
}

void prepareCorrection(int direction, bool strongCorrection)
{
  correctionDirection = direction;
  activeCorrectionPulseMs = strongCorrection ? STRONG_CORRECTION_PULSE_MS : CORRECTION_PULSE_MS;
  enterState(PRE_CORRECT_STOP);
}

void prepareRightAngleTurn(int direction)
{
  pendingTurnDirection = direction;
  enterState(direction < 0 ? PRE_TURN_FORWARD_LEFT : PRE_TURN_FORWARD_RIGHT);
}

void printSensors(const char *label)
{
  if (millis() - lastPrintMs < 100)
  {
    return;
  }

  Serial.print(label);
  Serial.print(" [R,SR,M,SL,L]: ");

  for (uint8_t i = 0; i < SENSOR_COUNT; i++)
  {
    Serial.print(sensorValues[i]);
    Serial.print(sensorOnLine[i] ? "*" : " ");
    Serial.print(" ");
  }

  Serial.print("| lastDir=");
  Serial.print(lastDirection);
  Serial.print(" corrDir=");
  Serial.print(correctionDirection);
  Serial.print(" routeTurn=");
  Serial.print(completedRouteTurns);
  Serial.print(" yaw=");
  Serial.println(yawDeg, 1);

  lastPrintMs = millis();
}

void enterState(RobotState nextState)
{
  state = nextState;
  stateStartMs = millis();

  switch (state)
  {
    case SENSE_LINE:
      break;

    case FORWARD_PULSE:
      Serial.println("State: FORWARD_PULSE");
      break;

    case SENSOR_SETTLE:
      stopAllMotors();
      break;

    case PRE_CORRECT_STOP:
      Serial.println("State: PRE_CORRECT_STOP");
      stopAllMotors();
      break;

    case CORRECT_LEFT:
      Serial.println("State: CORRECT_LEFT");
      break;

    case CORRECT_RIGHT:
      Serial.println("State: CORRECT_RIGHT");
      break;

    case AFTER_CORRECT_SETTLE:
      stopAllMotors();
      break;

    case PRE_TURN_FORWARD_LEFT:
      Serial.println("State: PRE_TURN_FORWARD_LEFT");
      Serial.print("PRE_TURN | target cm=");
      Serial.print(PRE_TURN_FORWARD_CM, 1);
      Serial.print(" ms=");
      Serial.println(PRE_TURN_FORWARD_MS);
      break;

    case PRE_TURN_FORWARD_RIGHT:
      Serial.println("State: PRE_TURN_FORWARD_RIGHT");
      Serial.print("PRE_TURN | target cm=");
      Serial.print(PRE_TURN_FORWARD_CM, 1);
      Serial.print(" ms=");
      Serial.println(PRE_TURN_FORWARD_MS);
      break;

    case TURN_LEFT_90:
      turnStartYawDeg = yawDeg;
      lastTurnDirection = -1;
      Serial.println("State: TURN_LEFT_90");
      break;

    case TURN_RIGHT_90:
      turnStartYawDeg = yawDeg;
      lastTurnDirection = 1;
      Serial.println("State: TURN_RIGHT_90");
      break;

    case AFTER_TURN_SETTLE:
      stopAllMotors();
      break;

    case FIND_LINE_SMALL_LEFT:
      Serial.println("State: FIND_LINE_SMALL_LEFT");
      break;

    case FIND_LINE_SMALL_RIGHT:
      Serial.println("State: FIND_LINE_SMALL_RIGHT");
      break;

    case FIND_LINE_BIG_LEFT:
      Serial.println("State: FIND_LINE_BIG_LEFT");
      break;

    case FIND_LINE_BIG_RIGHT:
      Serial.println("State: FIND_LINE_BIG_RIGHT");
      break;

    case LINE_LOST_STOP:
      Serial.println("State: LINE_LOST_STOP");
      stopAllMotors();
      break;
  }
}

void senseLineStep()
{
  readSensors();
  printSensors(SENSOR_DEBUG_MODE ? "QTR_DEBUG" : "SENSE");

  if (SENSOR_DEBUG_MODE)
  {
    stopAllMotors();
    return;
  }

  // Sensor order: [0] right, [1] slight right, [2] middle,
  // [3] slight left, [4] left.
  bool allowRightAngle = millis() >= ignoreRightAngleUntilMs;
  bool leftAngle = allowRightAngle && leftRightAngleRequested();
  bool rightAngle = allowRightAngle && rightRightAngleRequested();
  bool intersection = allowRightAngle && intersectionRequested();

  if (completedRouteTurns == 0 && leftAngle)
  {
    lastDirection = -1;
    prepareRightAngleTurn(-1);
    return;
  }

  if (completedRouteTurns == 1 && (intersection || rightAngle))
  {
    lastDirection = 1;
    prepareRightAngleTurn(1);
    return;
  }

  if (completedRouteTurns >= 2)
  {
    if (leftAngle && !rightAngle)
    {
      lastDirection = -1;
      prepareRightAngleTurn(-1);
      return;
    }

    if (rightAngle && !leftAngle)
    {
      lastDirection = 1;
      prepareRightAngleTurn(1);
      return;
    }
  }

  if (sensorOnLine[2])
  {
    lastDirection = 0;
    correctionDirection = 0;
    activeCorrectionPulseMs = CORRECTION_PULSE_MS;
    enterState(FORWARD_PULSE);
    return;
  }

  bool leftNeedsCorrection = leftCorrectionRequested();
  bool rightNeedsCorrection = rightCorrectionRequested();

  if (leftNeedsCorrection && !rightNeedsCorrection)
  {
    lastDirection = -1;

    if (ENABLE_LINE_CORRECTION)
    {
      prepareCorrection(-1, leftStrongCorrectionRequested());
    }
    else
    {
      stopAllMotors();
    }
    return;
  }

  if (rightNeedsCorrection && !leftNeedsCorrection)
  {
    lastDirection = 1;

    if (ENABLE_LINE_CORRECTION)
    {
      prepareCorrection(1, rightStrongCorrectionRequested());
    }
    else
    {
      stopAllMotors();
    }
    return;
  }

  if (sensorOnLine[3] || sensorOnLine[4])
  {
    lastDirection = -1;
    stopAllMotors();
    return;
  }

  if (sensorOnLine[1] || sensorOnLine[0])
  {
    lastDirection = 1;
    stopAllMotors();
    return;
  }

  stopAllMotors();
}

void correctionStep()
{
  readSensors();
  printSensors(correctionDirection < 0 ? "CORRECT_LEFT" : "CORRECT_RIGHT");

  if (millis() - stateStartMs >= activeCorrectionPulseMs)
  {
    stopAllMotors();
    enterState(AFTER_CORRECT_SETTLE);
    return;
  }

  if (correctionDirection < 0)
  {
    pivotLeft(max(PIVOT_SPEED, MIN_CORRECTION_SPEED));
  }
  else if (correctionDirection > 0)
  {
    pivotRight(max(PIVOT_SPEED, MIN_CORRECTION_SPEED));
  }
  else
  {
    stopAllMotors();
  }
}

void printTurnStatus(const char *label)
{
  if (millis() - lastPrintMs < 100)
  {
    return;
  }

  lastPrintMs = millis();
  Serial.print("TURN | ");
  Serial.print(label);
  Serial.print(" yaw=");
  Serial.print(yawDeg, 1);
  Serial.print(" delta=");
  Serial.print(rightAngleTurnDeg(), 1);
  Serial.print("/");
  Serial.println(RIGHT_ANGLE_TARGET_DEG, 1);
}

void rightAngleTurnStep(bool turnLeft)
{
  printTurnStatus(turnLeft ? "LEFT_90" : "RIGHT_90");

  if (rightAngleTurnDeg() >= RIGHT_ANGLE_TARGET_DEG)
  {
    stopAllMotors();
    completedRouteTurns++;
    pendingTurnDirection = 0;
    enterState(AFTER_TURN_SETTLE);
    return;
  }

  if (millis() - stateStartMs >= RIGHT_ANGLE_TIMEOUT_MS)
  {
    Serial.println("TURN | Timeout before IMU target.");
    stopAllMotors();
    completedRouteTurns++;
    pendingTurnDirection = 0;
    enterState(AFTER_TURN_SETTLE);
    return;
  }

  int16_t speed = rightAngleTurnDeg() >= RIGHT_ANGLE_SLOW_DOWN_DEG ? RIGHT_ANGLE_SLOW_SPEED : RIGHT_ANGLE_FAST_SPEED;

  if (turnLeft)
  {
    pivotLeft(speed);
  }
  else
  {
    pivotRight(speed);
  }
}

void enterFirstFindLineState()
{
  if (lastTurnDirection < 0)
  {
    findLineFirstDirection = -1;
    enterState(FIND_LINE_SMALL_LEFT);
  }
  else
  {
    findLineFirstDirection = 1;
    enterState(FIND_LINE_SMALL_RIGHT);
  }
}

bool isFirstFindLineDirection(bool turnLeft)
{
  return (turnLeft && findLineFirstDirection < 0) ||
         (!turnLeft && findLineFirstDirection > 0);
}

uint16_t findLineSmallDuration(bool turnLeft)
{
  return isFirstFindLineDirection(turnLeft) ? FIND_LINE_SMALL_MS : FIND_LINE_SMALL_MS * 2;
}

uint16_t findLineBigDuration(bool turnLeft)
{
  return isFirstFindLineDirection(turnLeft) ? FIND_LINE_BIG_MS : FIND_LINE_BIG_MS * 2;
}

RobotState nextSmallFindLineState(bool turnLeft)
{
  if (isFirstFindLineDirection(turnLeft))
  {
    return turnLeft ? FIND_LINE_SMALL_RIGHT : FIND_LINE_SMALL_LEFT;
  }

  return findLineFirstDirection < 0 ? FIND_LINE_BIG_LEFT : FIND_LINE_BIG_RIGHT;
}

RobotState nextBigFindLineState(bool turnLeft)
{
  if (isFirstFindLineDirection(turnLeft))
  {
    return turnLeft ? FIND_LINE_BIG_RIGHT : FIND_LINE_BIG_LEFT;
  }

  return LINE_LOST_STOP;
}

void findLineStep(bool turnLeft, uint16_t durationMs, RobotState nextState)
{
  if (centerOrAnySensorOnLine())
  {
    stopAllMotors();
    ignoreRightAngleUntilMs = millis() + 600;
    enterState(SENSE_LINE);
    return;
  }

  if (millis() - stateStartMs >= durationMs)
  {
    stopAllMotors();
    enterState(nextState);
    return;
  }

  if (turnLeft)
  {
    pivotLeft(FIND_LINE_SPEED);
  }
  else
  {
    pivotRight(FIND_LINE_SPEED);
  }
}

void setupMotoron(MotoronI2C &mc, uint8_t m1, uint8_t m2 = 0, uint8_t m3 = 0)
{
  mc.setBus(&Wire1);
  mc.reinitialize();
  mc.disableCrc();
  mc.clearResetFlag();

  mc.setMaxAcceleration(m1, 800);
  mc.setMaxDeceleration(m1, 900);

  if (m2 != 0)
  {
    mc.setMaxAcceleration(m2, 800);
    mc.setMaxDeceleration(m2, 900);
  }

  if (m3 != 0)
  {
    mc.setMaxAcceleration(m3, 800);
    mc.setMaxDeceleration(m3, 900);
  }
}

void setup()
{
  Serial.begin(115200);
  delay(1000);

  Wire.begin();
  Wire.setClock(400000);
  scanI2CBus(Wire, "Wire IMU bus");

  while (!initIMU())
  {
    Serial.println("IMU | Not ready, retrying...");
    delay(500);
  }

  Wire1.begin();
  Wire1.setClock(400000);
  scanI2CBus(Wire1, "Wire1 for Motorons");

  setupMotoron(mcLower, RF, RR, LR);
  setupMotoron(mcUpper, LF);

  stopAllMotors();

  Serial.println("IMU | Keep car still for gyro calibration.");
  delay(1000);
  calibrateGyroZ();
  yawDeg = 0.0;
  turnStartYawDeg = 0.0;
  lastUpdateMicros = micros();

  Serial.println("Line follower ready. Lower=0x10, Upper=0x11, IMU right-angle turns enabled.");
  Serial.println("Correction enabled: side sensors correct; strong outer sensors trigger 90-degree IMU turns.");
  delay(1000);

  enterState(SENSE_LINE);
}

void loop()
{
  updateYaw();

  switch (state)
  {
    case SENSE_LINE:
      senseLineStep();
      break;

    case FORWARD_PULSE:
      driveForward(FORWARD_SPEED);
      if (millis() - stateStartMs >= FORWARD_PULSE_MS)
      {
        stopAllMotors();
        enterState(SENSOR_SETTLE);
      }
      break;

    case SENSOR_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= SENSOR_SETTLE_MS)
      {
        enterState(SENSE_LINE);
      }
      break;

    case PRE_CORRECT_STOP:
      stopAllMotors();
      if (millis() - stateStartMs >= PRE_CORRECT_STOP_MS)
      {
        if (correctionDirection < 0)
        {
          enterState(CORRECT_LEFT);
        }
        else if (correctionDirection > 0)
        {
          enterState(CORRECT_RIGHT);
        }
        else
        {
          enterState(SENSE_LINE);
        }
      }
      break;

    case CORRECT_LEFT:
    case CORRECT_RIGHT:
      correctionStep();
      break;

    case AFTER_CORRECT_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= AFTER_CORRECT_SETTLE_MS)
      {
        enterState(SENSE_LINE);
      }
      break;

    case PRE_TURN_FORWARD_LEFT:
      driveForward(FORWARD_SPEED);
      if (millis() - stateStartMs >= PRE_TURN_FORWARD_MS)
      {
        stopAllMotors();
        enterState(TURN_LEFT_90);
      }
      break;

    case PRE_TURN_FORWARD_RIGHT:
      driveForward(FORWARD_SPEED);
      if (millis() - stateStartMs >= PRE_TURN_FORWARD_MS)
      {
        stopAllMotors();
        enterState(TURN_RIGHT_90);
      }
      break;

    case TURN_LEFT_90:
      rightAngleTurnStep(true);
      break;

    case TURN_RIGHT_90:
      rightAngleTurnStep(false);
      break;

    case AFTER_TURN_SETTLE:
      stopAllMotors();
      if (millis() - stateStartMs >= AFTER_TURN_SETTLE_MS)
      {
        enterFirstFindLineState();
      }
      break;

    case FIND_LINE_SMALL_LEFT:
      findLineStep(true, findLineSmallDuration(true), nextSmallFindLineState(true));
      break;

    case FIND_LINE_SMALL_RIGHT:
      findLineStep(false, findLineSmallDuration(false), nextSmallFindLineState(false));
      break;

    case FIND_LINE_BIG_LEFT:
      findLineStep(true, findLineBigDuration(true), nextBigFindLineState(true));
      break;

    case FIND_LINE_BIG_RIGHT:
      findLineStep(false, findLineBigDuration(false), nextBigFindLineState(false));
      break;

    case LINE_LOST_STOP:
      stopAllMotors();
      break;
  }

  delay(5);
}
